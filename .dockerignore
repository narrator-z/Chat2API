# Node modules (will be installed in container)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs (will be copied separately)
dist/
build/
out/

# Development files
src/
*.ts
*.tsx
*.js.map
*.ts.map

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Configuration (will be mounted as volume)
config.json
accounts.json
providers.json

# Documentation
README.md
docs/

# Git
.git/
.gitignore

# CI/CD
.github/
.gitlab-ci.yml

# Temporary files
tmp/
temp/
*.tmp

# Package manager files
package-lock.json
yarn.lock

# Test files
test/
tests/
*.test.*
*.spec.*
